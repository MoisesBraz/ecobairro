# Build Stage
FROM node:22-alpine AS builder

RUN corepack enable
WORKDIR /workspace

# Copy root configs
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY packages/ ./packages/
COPY apps/api/package.json ./apps/api/

# Install all dependencies
RUN pnpm install --frozen-lockfile

# Copy app source
COPY apps/api/ ./apps/api/

# Build @ecobairro/config
RUN pnpm --filter @ecobairro/config build

# Generate Prisma Client
RUN pnpm --filter @ecobairro/api exec prisma generate

# Build API
RUN pnpm --filter @ecobairro/api build

# Deploy: creates self-contained folder without symlinks
RUN pnpm --filter @ecobairro/api deploy --prod --legacy /deploy

# Copy built dist
RUN cp -r /workspace/apps/api/dist /deploy/dist

# Ensure prisma schema is in deploy and generate client inside production node_modules
RUN cp -r /workspace/apps/api/prisma /deploy/prisma
RUN cd /deploy && npx prisma generate

# Production Stage
FROM node:22-alpine

WORKDIR /app
COPY --from=builder /deploy .

ENV NODE_ENV=production
EXPOSE 3000

CMD ["sh", "-c", "npx prisma migrate deploy && node dist/main.js"]
