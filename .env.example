# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ecobairro
POSTGRES_USER=ecobairro
POSTGRES_PASSWORD=ecobairro
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_PORT=8080

# ── API – JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# ── API – Segurança ───────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# Origins permitidas para CORS (separadas por vírgula se necessário)
CORS_ORIGIN=http://localhost:5173

# ── API – Aplicação ───────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
PORT=3000

# ── API – Reset de Password ───────────────────────────────────────────────────
PASSWORD_RESET_TTL_MINUTES=30
# Em desenvolvimento, força o token no body (ignora email). Deixe false com Mailpit.
PASSWORD_RESET_RETURN_TOKEN=false

# ── SMTP (email) ──────────────────────────────────────────────────────────────
# SMTP config. Para testar com Mailpit local, use SMTP_HOST=mailpit e SMTP_PORT=1025
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
# Opcional — Mailpit não exige autenticação; preencha para SMTP real (ex. SendGrid)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ecobairro.local
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# URL base da API (usada no browser)
VITE_API_BASE_URL=http://localhost:8080
